<Page x:Class="CursorCage.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:CursorCage.Models"
      mc:Ignorable="d"
      Title="Paramètres">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Paramètres"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20" />
            <TextBlock Text="Raccourci global (verrouiller / déverrouiller)"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <TextBlock TextWrapping="Wrap"
                       Foreground="#555"
                       Margin="0,0,0,8"
                       Text="Cliquez dans la zone puis appuyez sur la combinaison souhaitée (ex. Ctrl+L). Échap rétablit le défaut (Ctrl+L)." />
            <Border BorderBrush="#CCC"
                    BorderThickness="1"
                    Background="White"
                    Padding="12"
                    Margin="0,0,0,8">
                <TextBox x:Name="HotkeyDisplay"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Focusable="True"
                         PreviewKeyDown="HotkeyDisplay_PreviewKeyDown"
                         FontSize="16"
                         Text="(aucun)" />
            </Border>
            <TextBlock x:Name="HotkeyStatus"
                       Foreground="#C62828"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"
                       Visibility="Collapsed" />
            <TextBlock Text="Zone de verrouillage"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <ComboBox x:Name="ModeCombo" Margin="0,0,0,16">
                <ComboBoxItem Tag="{x:Static models:LockTargetMode.ActiveWindow}"
                              Content="Fenêtre au premier plan"
                              IsSelected="True" />
                <ComboBoxItem Tag="{x:Static models:LockTargetMode.ScreenUnderCursor}"
                              Content="Écran sous le curseur au moment du verrouillage" />
            </ComboBox>
            <CheckBox x:Name="AutoGameCheck"
                      Content="Verrouillage automatique au lancement d'un jeu (bientôt)"
                      IsEnabled="False"
                      Margin="0,0,0,20" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Enregistrer"
                        Padding="20,10"
                        Margin="0,0,10,0"
                        Click="Save_Click" />
                <Button Content="Réinitialiser le raccourci"
                        Padding="20,10"
                        Click="ResetHotkey_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
