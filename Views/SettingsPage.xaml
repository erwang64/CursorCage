<Page x:Class="CursorCage.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Paramètres">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Paramètres"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20" />
            <TextBlock x:Name="SettingsPathText"
                       TextWrapping="Wrap"
                       Foreground="#666"
                       FontSize="12"
                       Margin="0,0,0,16" />
            <TextBlock Text="Raccourci global (verrouiller / déverrouiller)"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <TextBlock TextWrapping="Wrap"
                       Foreground="#555"
                       Margin="0,0,0,8"
                       Text="Modifiez ci-dessous : tout est enregistré automatiquement sur le disque. Vous pouvez aussi cliquer dans la zone puis appuyer sur la combinaison (Échap = défaut Ctrl+L)." />
            <Border BorderBrush="#CCC"
                    BorderThickness="1"
                    Background="White"
                    Padding="12"
                    Margin="0,0,0,8">
                <TextBox x:Name="HotkeyDisplay"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Focusable="True"
                         PreviewKeyDown="HotkeyDisplay_PreviewKeyDown"
                         FontSize="16"
                         Text="(aucun)" />
            </Border>
            <TextBlock Text="Ou choisissez manuellement :"
                       Foreground="#555"
                       Margin="0,0,0,8" />
            <WrapPanel Margin="0,0,0,8">
                <CheckBox x:Name="CtrlCheck"
                          Content="Ctrl"
                          Margin="0,0,12,0"
                          Checked="ModifierOrKey_Changed"
                          Unchecked="ModifierOrKey_Changed" />
                <CheckBox x:Name="AltCheck"
                          Content="Alt"
                          Margin="0,0,12,0"
                          Checked="ModifierOrKey_Changed"
                          Unchecked="ModifierOrKey_Changed" />
                <CheckBox x:Name="ShiftCheck"
                          Content="Maj"
                          Margin="0,0,12,0"
                          Checked="ModifierOrKey_Changed"
                          Unchecked="ModifierOrKey_Changed" />
                <CheckBox x:Name="WinCheck"
                          Content="Win"
                          Checked="ModifierOrKey_Changed"
                          Unchecked="ModifierOrKey_Changed" />
            </WrapPanel>
            <ComboBox x:Name="KeyCombo"
                      Width="280"
                      Margin="0,0,0,8"
                      DisplayMemberPath="Label"
                      SelectedValuePath="VirtualKey"
                      SelectionChanged="KeyCombo_SelectionChanged" />
            <TextBlock x:Name="HotkeyStatus"
                       Foreground="#C62828"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"
                       Visibility="Collapsed" />
            <TextBlock Text="Zone de verrouillage"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <Border BorderBrush="#DDD"
                    BorderThickness="1"
                    Background="#FAFAFA"
                    Padding="10"
                    Margin="0,0,0,16">
                <TextBlock TextWrapping="Wrap"
                           Text="Mode forcé : verrouillage de l’écran courant (multi-écran bloqué sur le moniteur actuel)." />
            </Border>
            <CheckBox x:Name="AutoGameCheck"
                      Content="Verrouillage automatique au lancement d'un jeu (bientôt)"
                      IsEnabled="False"
                      Margin="0,0,0,20" />
            <Button Content="Réinitialiser le raccourci"
                    HorizontalAlignment="Left"
                    Padding="20,10"
                    Click="ResetHotkey_Click" />
        </StackPanel>
    </ScrollViewer>
</Page>
