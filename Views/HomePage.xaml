<Page x:Class="CursorCage.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="{DynamicResource StrHomeTitle}">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource StrHomeTitle}"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="{StaticResource MainText}"
                   Margin="0,0,0,8" />

        <TextBlock x:Name="HelpText"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource SecondaryText}"
                   FontSize="15"
                   LineHeight="22"
                   MaxWidth="600"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,32"
                   Text="{DynamicResource StrHomeDesc}" />

        <Border Grid.Row="2"
                Padding="32"
                Background="{StaticResource BgLighter}"
                BorderBrush="{StaticResource BorderMedium}"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Left"
                MinWidth="500">
            <StackPanel>
                <TextBlock x:Name="StatusLabel"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MainText}"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="ModeLabel"
                           Foreground="{StaticResource SecondaryText}"
                           FontSize="14"
                           Margin="0,0,0,32" />
                
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnLock"
                            Content="{DynamicResource StrBtnLock}"
                            Style="{StaticResource AccentButton}"
                            Padding="24,12"
                            FontSize="15"
                            Margin="0,0,12,0"
                            Click="BtnLock_Click" />
                    <Button x:Name="BtnUnlock"
                            Content="{DynamicResource StrBtnUnlock}"
                            Padding="24,12"
                            FontSize="15"
                            Margin="0,0,12,0"
                            Click="BtnUnlock_Click" />
                    <Button Content="{DynamicResource StrBtnToggle}"
                            Padding="24,12"
                            FontSize="15"
                            Click="BtnToggle_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
