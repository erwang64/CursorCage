<Application x:Class="CursorCage.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Lang.en.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <Color x:Key="BgDarkColor">#222222</Color>
        <Color x:Key="BgDarkerColor">#1A1A1A</Color>
        <Color x:Key="BgLighterColor">#333333</Color>
        <Color x:Key="AccentColor">#89B4FA</Color>
        
        <SolidColorBrush x:Key="BgDark" Color="{StaticResource BgDarkColor}" />
        <SolidColorBrush x:Key="BgDarker" Color="{StaticResource BgDarkerColor}" />
        <SolidColorBrush x:Key="BgLighter" Color="{StaticResource BgLighterColor}" />
        <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentHover" Color="#B4BEFE" />
        <SolidColorBrush x:Key="MainText" Color="#E5E5E5" />
        <SolidColorBrush x:Key="SecondaryText" Color="#A5A5A5" />
        <SolidColorBrush x:Key="BorderMedium" Color="#444444" />

        <Style TargetType="Page">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MainText}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="TextElement.Foreground" Value="#111111" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="TextElement.Foreground" Value="#111111" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainText}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgLighter}" />
            <Setter Property="Foreground" Value="{StaticResource MainText}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderMedium}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BorderMedium}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Accent}" />
                                <Setter Property="Foreground" Value="#111111" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#749FE2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
